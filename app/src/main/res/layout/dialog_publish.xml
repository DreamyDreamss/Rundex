<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_bg"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📣 피드에 공유"
        android:textColor="@color/textDark"
        android:textSize="19sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="오늘 러닝에 한마디 남겨보세요."
        android:textColor="@color/textGrey"
        android:textSize="13sp" />

    <EditText
        android:id="@+id/captionInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/edit_field_bg"
        android:gravity="top"
        android:hint="예) 한강 노을 보며 가볍게 🏃"
        android:inputType="textMultiLine"
        android:maxLength="140"
        android:minLines="2"
        android:padding="14dp"
        android:textColor="@color/textDark"
        android:textColorHint="@color/textGrey"
        android:textSize="15sp" />

    <EditText
        android:id="@+id/tagsInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/edit_field_bg"
        android:hint="태그 (예: 한강 야간런 5K)"
        android:inputType="text"
        android:maxLength="80"
        android:padding="14dp"
        android:textColor="@color/textDark"
        android:textColorHint="@color/textGrey"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnPrivate"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/btn_secondary"
            android:gravity="center"
            android:text="🔒 비공개"
            android:textColor="@color/textDark"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Space android:layout_width="12dp" android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/btnPublish"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/btn_primary"
            android:gravity="center"
            android:text="🔓 공개"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
