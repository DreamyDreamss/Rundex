<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <org.maplibre.android.maps.MapView
            android:id="@+id/trackMapView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/search_bg"
                android:elevation="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_search"
                    android:contentDescription="검색" />

                <EditText
                    android:id="@+id/searchInput"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="주소·장소 검색"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:maxLines="1"
                    android:paddingStart="12dp"
                    android:paddingEnd="8dp"
                    android:singleLine="true"
                    android:textColor="@color/textDark"
                    android:textColorHint="@color/textGrey"
                    android:textSize="15sp" />

                <ImageView
                    android:id="@+id/searchClear"
                    android:layout_width="40dp"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:contentDescription="지우기"
                    android:visibility="gone" />
            </LinearLayout>

            <ListView
                android:id="@+id/searchSuggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/suggestions_bg"
                android:divider="@color/divider"
                android:dividerHeight="1dp"
                android:elevation="6dp"
                android:maxHeight="276dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/statsText"
            android:lineSpacingExtra="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/card_bg"
                android:elevation="4dp"
                android:padding="16dp"
                android:text="기록 대기 중"
                android:textColor="@color/textDark"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/startStopButton"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:background="@drawable/btn_primary"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:text="기록 시작"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/historyButton"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/btn_secondary"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:text="저장된 기록"
                android:textColor="@color/textDark"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>

    <include layout="@layout/bottom_nav" />
</LinearLayout>
