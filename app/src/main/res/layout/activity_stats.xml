<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/insBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="‹"
            android:textColor="@color/textDark"
            android:textSize="30sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📊 러닝 인사이트"
            android:textColor="@color/textDark"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- 주간 거리 차트 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="14dp"
                android:background="@drawable/card_bg"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="주간 거리 (최근 8주)"
                    android:textColor="@color/textDark"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/insWeekTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/textGrey"
                    android:textSize="12sp" />

                <com.rundex.routepoc.BarChartView
                    android:id="@+id/insChart"
                    android:layout_width="match_parent"
                    android:layout_height="170dp"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

            <!-- 최고 기록 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="4dp"
                android:text="🏅 최고 기록"
                android:textColor="@color/textDark"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="14dp"
                android:background="@drawable/card_bg"
                android:elevation="2dp"
                android:orientation="horizontal"
                android:paddingTop="18dp"
                android:paddingBottom="18dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/insLongest" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:fontFeatureSettings="tnum" android:text="-" android:textColor="@color/primary" android:textSize="19sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="최장 거리" android:textColor="@color/textGrey" android:textSize="11sp" />
                </LinearLayout>
                <View android:layout_width="1dp" android:layout_height="32dp" android:layout_gravity="center_vertical" android:background="@color/divider" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/insBestPace" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:fontFeatureSettings="tnum" android:text="-" android:textColor="@color/accent" android:textSize="19sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="최고 페이스" android:textColor="@color/textGrey" android:textSize="11sp" />
                </LinearLayout>
                <View android:layout_width="1dp" android:layout_height="32dp" android:layout_gravity="center_vertical" android:background="@color/divider" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/insLongestTime" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:fontFeatureSettings="tnum" android:text="-" android:textColor="@color/textDark" android:textSize="19sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="최장 시간" android:textColor="@color/textGrey" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 누적 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/card_bg"
                android:elevation="2dp"
                android:orientation="horizontal"
                android:paddingTop="18dp"
                android:paddingBottom="18dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/insMonth" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:fontFeatureSettings="tnum" android:text="-" android:textColor="@color/textDark" android:textSize="19sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="이번 달" android:textColor="@color/textGrey" android:textSize="11sp" />
                </LinearLayout>
                <View android:layout_width="1dp" android:layout_height="32dp" android:layout_gravity="center_vertical" android:background="@color/divider" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/insTotal" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:fontFeatureSettings="tnum" android:text="-" android:textColor="@color/textDark" android:textSize="19sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="누적 거리" android:textColor="@color/textGrey" android:textSize="11sp" />
                </LinearLayout>
                <View android:layout_width="1dp" android:layout_height="32dp" android:layout_gravity="center_vertical" android:background="@color/divider" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/insRuns" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:fontFeatureSettings="tnum" android:text="-" android:textColor="@color/textDark" android:textSize="19sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="총 러닝" android:textColor="@color/textGrey" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
