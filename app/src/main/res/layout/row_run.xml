<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="14dp"
    android:paddingTop="7dp"
    android:paddingEnd="14dp"
    android:paddingBottom="7dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_bg"
        android:elevation="2dp"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- 헤더: 날짜 + 공개여부 배지 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/runAvatar"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_icon_circle"
                android:gravity="center"
                android:text="🏃"
                android:textSize="19sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="11dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/runDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/textDark"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/runWhen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:textColor="@color/textGrey"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/runBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/chip_bg"
                android:paddingStart="11dp"
                android:paddingTop="5dp"
                android:paddingEnd="11dp"
                android:paddingBottom="5dp"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 경로 미리보기 -->
        <com.rundex.routepoc.RoutePreviewView
            android:id="@+id/runRoute"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_inset" />

        <!-- 캡션 -->
        <TextView
            android:id="@+id/runCaption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/textDark"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- 태그 -->
        <TextView
            android:id="@+id/runTags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- 통계 4열: 거리 / 시간 / 평균 페이스 / 지나는 동 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <TextView android:id="@+id/runStatKm" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:fontFeatureSettings="tnum" android:textColor="@color/textDark" android:textSize="16sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="거리" android:textColor="@color/textGrey" android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <TextView android:id="@+id/runStatTime" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:fontFeatureSettings="tnum" android:textColor="@color/textDark" android:textSize="16sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="시간" android:textColor="@color/textGrey" android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <TextView android:id="@+id/runStatPace" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:fontFeatureSettings="tnum" android:textColor="@color/textDark" android:textSize="16sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="평균 페이스" android:textColor="@color/textGrey" android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <TextView android:id="@+id/runStatRegions" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:fontFeatureSettings="tnum" android:textColor="@color/textDark" android:textSize="16sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="지나는 동" android:textColor="@color/textGrey" android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 하단: 좋아요 수 + 상세 보기 + 공개전환 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/runLikes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="❤️ 0"
                android:textColor="@color/textGrey"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/runDetailBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/chip_bg"
                android:paddingStart="14dp"
                android:paddingTop="8dp"
                android:paddingEnd="14dp"
                android:paddingBottom="8dp"
                android:text="🗺 상세"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/runVisBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/chip_bg"
                android:paddingStart="14dp"
                android:paddingTop="8dp"
                android:paddingEnd="14dp"
                android:paddingBottom="8dp"
                android:textColor="@color/textDark"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
