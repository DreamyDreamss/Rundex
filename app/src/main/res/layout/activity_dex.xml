<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <org.maplibre.android.maps.MapView
            android:id="@+id/dexMapView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- 상단 요약 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_margin="14dp"
            android:background="@drawable/card_bg"
            android:elevation="6dp"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="14dp"
            android:paddingEnd="20dp"
            android:paddingBottom="14dp">

            <TextView
                android:id="@+id/dexHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/textDark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/dexCompletion"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="8dp"
                android:max="1000"
                android:progressTint="@color/primary" />
        </LinearLayout>

        <!-- 등급 범례 (좌하단) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="14dp"
            android:background="@drawable/card_bg"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="등급"
                android:textColor="@color/textGrey"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView android:id="@+id/legCard" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="● 카드" android:textColor="@color/gradeCard" android:textSize="12sp" />
            <TextView android:id="@+id/legBronze" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="3dp" android:text="● 브론즈" android:textColor="@color/gradeBronze" android:textSize="12sp" />
            <TextView android:id="@+id/legSilver" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="3dp" android:text="● 실버" android:textColor="@color/gradeSilver" android:textSize="12sp" />
            <TextView android:id="@+id/legGold" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="3dp" android:text="● 골드" android:textColor="@color/gradeGold" android:textSize="12sp" />
        </LinearLayout>

        <!-- 테마 도감 (우하단 칩) -->
        <TextView
            android:id="@+id/openThemeDexButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="14dp"
            android:background="@drawable/btn_primary"
            android:elevation="6dp"
            android:paddingStart="18dp"
            android:paddingTop="13dp"
            android:paddingEnd="18dp"
            android:paddingBottom="13dp"
            android:text="🌟 테마 도감"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- 빈 상태 -->
        <TextView
            android:id="@+id/dexEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/card_bg"
            android:elevation="4dp"
            android:gravity="center"
            android:padding="22dp"
            android:text="아직 발견한 동이 없어요.\n달리면 이 지도가 색으로 채워집니다 🎨"
            android:textColor="@color/textGrey"
            android:textSize="14sp"
            android:visibility="gone" />
    </FrameLayout>

    <include layout="@layout/bottom_nav" />
</LinearLayout>
