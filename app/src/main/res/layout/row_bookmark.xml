<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="14dp"
    android:paddingTop="6dp"
    android:paddingEnd="14dp"
    android:paddingBottom="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_bg"
        android:elevation="2dp"
        android:orientation="vertical"
        android:padding="14dp">

        <com.rundex.routepoc.RoutePreviewView
            android:id="@+id/bmRoute"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="@drawable/card_inset" />

        <TextView
            android:id="@+id/bmName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/textDark"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/bmSub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/textGrey"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/bmRun"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="46dp"
                android:background="@drawable/btn_primary"
                android:gravity="center"
                android:text="🏃 이 코스로 달리기"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/bmRemove"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/btn_circle_secondary"
                android:gravity="center"
                android:text="🗑"
                android:textSize="18sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
