<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <!-- 앱바 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/viewBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="‹"
            android:textColor="@color/textDark"
            android:textSize="30sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🏃 러닝 기록"
            android:textColor="@color/textDark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/viewBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/chip_bg"
            android:paddingStart="11dp"
            android:paddingTop="5dp"
            android:paddingEnd="11dp"
            android:paddingBottom="5dp"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 거리 헤드라인 -->
            <TextView
                android:id="@+id/viewDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="6dp"
                android:fontFeatureSettings="tnum"
                android:text="0.00 km"
                android:textColor="@color/textDark"
                android:textSize="40sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/viewDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="2dp"
                android:textColor="@color/textGrey"
                android:textSize="13sp" />

            <!-- 캡션 -->
            <TextView
                android:id="@+id/viewCaption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="20dp"
                android:textColor="@color/textDark"
                android:textSize="15sp"
                android:visibility="gone" />

            <!-- 태그 -->
            <TextView
                android:id="@+id/viewTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="20dp"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- 운동 상세정보 카드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="14dp"
                android:background="@drawable/card_bg"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="운동 상세정보"
                    android:textColor="@color/textDark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- 1행: 운동 시간 / 평균 페이스 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="16dp" android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="운동 시간" android:textColor="@color/textGrey" android:textSize="12sp" />
                        <TextView android:id="@+id/stTime" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="2dp" android:fontFeatureSettings="tnum" android:text="0:00"
                            android:textColor="@color/accent" android:textSize="23sp" android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="평균 페이스" android:textColor="@color/textGrey" android:textSize="12sp" />
                        <TextView android:id="@+id/stPace" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="2dp" android:fontFeatureSettings="tnum" android:text="-'--&quot;/km"
                            android:textColor="@color/accent" android:textSize="23sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 2행: 평균 속도 / 운동 칼로리 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="18dp" android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="평균 속도" android:textColor="@color/textGrey" android:textSize="12sp" />
                        <TextView android:id="@+id/stSpeed" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="2dp" android:fontFeatureSettings="tnum" android:text="0.0 km/h"
                            android:textColor="@color/primary" android:textSize="23sp" android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="운동 칼로리" android:textColor="@color/textGrey" android:textSize="12sp" />
                        <TextView android:id="@+id/stKcal" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="2dp" android:fontFeatureSettings="tnum" android:text="0 kcal"
                            android:textColor="@color/statPink" android:textSize="23sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 3행: 누적 고도 / 지나는 동 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="18dp" android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="누적 고도" android:textColor="@color/textGrey" android:textSize="12sp" />
                        <TextView android:id="@+id/stElev" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="2dp" android:fontFeatureSettings="tnum" android:text="-"
                            android:textColor="@color/success" android:textSize="23sp" android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="지나는 동" android:textColor="@color/textGrey" android:textSize="12sp" />
                        <TextView android:id="@+id/stRegions" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="2dp" android:fontFeatureSettings="tnum" android:text="-"
                            android:textColor="@color/success" android:textSize="23sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 지도 카드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/card_bg"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🗺 지도"
                    android:textColor="@color/textDark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/card_inset">

                    <org.maplibre.android.maps.MapView
                        android:id="@+id/viewMapView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </FrameLayout>
            </LinearLayout>

            <!-- 구간 기록 카드 (스플릿 있을 때만) -->
            <LinearLayout
                android:id="@+id/splitsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="14dp"
                android:background="@drawable/card_bg"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="구간 기록 (1km)"
                    android:textColor="@color/textDark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- 헤더 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="구간" android:textColor="@color/textGrey" android:textSize="12sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2"
                        android:gravity="center" android:text="페이스(/km)" android:textColor="@color/textGrey" android:textSize="12sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="3"
                        android:text="" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/splitsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- 액션 버튼 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="14dp"
                android:layout_marginBottom="10dp"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/shareCardButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="52dp"
                    android:background="@drawable/btn_primary"
                    android:text="스토리 공유"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/exportGpxButton"
                    android:layout_width="wrap_content"
                    android:layout_height="52dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/btn_secondary"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:text="GPX"
                    android:textColor="@color/textDark"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/followCourseButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/btn_primary"
                    android:text="🏃 이 코스 따라 뛰기"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
