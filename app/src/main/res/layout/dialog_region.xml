<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_bg"
    android:orientation="vertical"
    android:padding="22dp">

    <!-- 헤더: 색 점 + 동 이름 + 등급 배지 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:id="@+id/regionDot"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="@drawable/dot_circle" />

        <TextView
            android:id="@+id/regionName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:textColor="@color/textDark"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/regionGradeBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/chip_bg"
            android:paddingStart="12dp"
            android:paddingTop="5dp"
            android:paddingEnd="12dp"
            android:paddingBottom="5dp"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 통계 3열 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:id="@+id/regionKm" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:fontFeatureSettings="tnum" android:textColor="@color/textDark" android:textSize="19sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="누적 거리" android:textColor="@color/textGrey" android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:id="@+id/regionGrade" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/textDark" android:textSize="19sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="등급" android:textColor="@color/textGrey" android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:id="@+id/regionRunCount" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:fontFeatureSettings="tnum" android:textColor="@color/textDark" android:textSize="19sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="러닝" android:textColor="@color/textGrey" android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="18dp"
        android:background="@color/divider" />

    <TextView
        android:id="@+id/regionRunsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="🏃 이 동네 러닝"
        android:textColor="@color/textDark"
        android:textSize="14sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:maxHeight="280dp">

        <LinearLayout
            android:id="@+id/regionRunsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <TextView
        android:id="@+id/regionClose"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/btn_primary"
        android:gravity="center"
        android:text="닫기"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold" />
</LinearLayout>
