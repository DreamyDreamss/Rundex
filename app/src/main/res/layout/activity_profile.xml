<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 헤더: 아바타 + 이름 + 대표 칭호 칩 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:elevation="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="20dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/avatar_bg"
                    android:gravity="center"
                    android:text="🏃"
                    android:textSize="40sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/profileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="러너"
                        android:textColor="@color/textDark"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/profileTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/chip_bg"
                        android:paddingStart="14dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="6dp"
                        android:textColor="@color/primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- 통계: 4열 인라인 카드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_bg"
                android:elevation="2dp"
                android:orientation="horizontal"
                android:paddingTop="18dp"
                android:paddingBottom="18dp">

                <TextView
                    android:id="@+id/statDistance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:lineSpacingExtra="3dp"
                    android:textColor="@color/textDark"
                    android:textSize="14sp" />

                <View android:layout_width="1dp" android:layout_height="32dp"
                    android:layout_gravity="center_vertical" android:background="@color/divider" />

                <TextView
                    android:id="@+id/statRuns"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:lineSpacingExtra="3dp"
                    android:textColor="@color/textDark"
                    android:textSize="14sp" />

                <View android:layout_width="1dp" android:layout_height="32dp"
                    android:layout_gravity="center_vertical" android:background="@color/divider" />

                <TextView
                    android:id="@+id/statDex"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:lineSpacingExtra="3dp"
                    android:textColor="@color/textDark"
                    android:textSize="14sp" />

                <View android:layout_width="1dp" android:layout_height="32dp"
                    android:layout_gravity="center_vertical" android:background="@color/divider" />

                <TextView
                    android:id="@+id/statTitles"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:lineSpacingExtra="3dp"
                    android:textColor="@color/textDark"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- 메뉴 -->
            <Button
                android:id="@+id/openTitlesButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/btn_secondary"
                android:text="🏅  칭호 보관함"
                android:textColor="@color/textDark"
                android:textSize="15sp" />

            <Button
                android:id="@+id/openRunsButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/btn_secondary"
                android:text="📜  러닝 기록"
                android:textColor="@color/textDark"
                android:textSize="15sp" />

            <Button
                android:id="@+id/openDiscoverButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/btn_secondary"
                android:text="🧭  추천 코스"
                android:textColor="@color/textDark"
                android:textSize="15sp" />

            <Button
                android:id="@+id/openFeedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/btn_secondary"
                android:text="📣  피드"
                android:textColor="@color/textDark"
                android:textSize="15sp" />

            <Button
                android:id="@+id/openUsersButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/btn_secondary"
                android:text="👥  친구 찾기"
                android:textColor="@color/textDark"
                android:textSize="15sp" />

            <Button
                android:id="@+id/openCrewButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/btn_secondary"
                android:text="🤝  크루"
                android:textColor="@color/textDark"
                android:textSize="15sp" />
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/bottom_nav" />
</LinearLayout>
