<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <!-- 상단 바: 이름 + ☰ 메뉴 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/profileTopName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="프로필"
            android:textColor="@color/textDark"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/menuButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="☰"
            android:textColor="@color/textDark"
            android:textSize="24sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="6dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <!-- 아바타 + 게시물/팔로워/팔로잉 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/profileAvatar"
                    android:layout_width="76dp"
                    android:layout_height="76dp"
                    android:background="@drawable/avatar_bg"
                    android:gravity="center"
                    android:text="🏃"
                    android:textSize="36sp" />

                <LinearLayout android:id="@+id/statPosts" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/postsCount" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:fontFeatureSettings="tnum" android:text="0" android:textColor="@color/textDark" android:textSize="20sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="게시물" android:textColor="@color/textGrey" android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout android:id="@+id/statFollowers" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/followersCount" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:fontFeatureSettings="tnum" android:text="0" android:textColor="@color/textDark" android:textSize="20sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="팔로워" android:textColor="@color/textGrey" android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout android:id="@+id/statFollowing" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/followingCount" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:fontFeatureSettings="tnum" android:text="0" android:textColor="@color/textDark" android:textSize="20sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="팔로잉" android:textColor="@color/textGrey" android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 이름 / 핸들 / 대표칭호 / 소개 -->
            <TextView
                android:id="@+id/profileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="러너"
                android:textColor="@color/textDark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/profileHandle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:textColor="@color/textGrey"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/profileTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/chip_bg"
                android:paddingStart="12dp"
                android:paddingTop="5dp"
                android:paddingEnd="12dp"
                android:paddingBottom="5dp"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/profileBio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/textDark"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- 프로필 편집 -->
            <TextView
                android:id="@+id/editProfileButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/btn_secondary"
                android:gravity="center"
                android:text="프로필 편집"
                android:textColor="@color/textDark"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- 🔥 스트릭 배너 -->
            <TextView
                android:id="@+id/streakBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/chip_bg"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- 러닝 통계 4칸 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_bg"
                android:elevation="2dp"
                android:orientation="horizontal"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <TextView android:id="@+id/statDistance" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:lineSpacingExtra="3dp"
                    android:textColor="@color/textDark" android:textSize="13sp" />
                <View android:layout_width="1dp" android:layout_height="32dp" android:layout_gravity="center_vertical" android:background="@color/divider" />
                <TextView android:id="@+id/statRuns" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:lineSpacingExtra="3dp"
                    android:textColor="@color/textDark" android:textSize="13sp" />
                <View android:layout_width="1dp" android:layout_height="32dp" android:layout_gravity="center_vertical" android:background="@color/divider" />
                <TextView android:id="@+id/statDex" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:lineSpacingExtra="3dp"
                    android:textColor="@color/textDark" android:textSize="13sp" />
                <View android:layout_width="1dp" android:layout_height="32dp" android:layout_gravity="center_vertical" android:background="@color/divider" />
                <TextView android:id="@+id/statTitles" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:lineSpacingExtra="3dp"
                    android:textColor="@color/textDark" android:textSize="13sp" />
            </LinearLayout>

            <!-- 게시물 / 러닝 기록 탭 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tabPosts"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:text="게시물"
                    android:textColor="@color/textDark"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tabRecords"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:text="러닝 기록"
                    android:textColor="@color/textGrey"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:id="@+id/tabIndicator"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/divider" />

            <!-- 게시물 올리기 (게시물 탭에서만) -->
            <TextView
                android:id="@+id/registerPost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/btn_secondary"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="＋ 러닝 기록에서 게시물 올리기"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/postsGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/postsEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="28dp"
                android:text="아직 기록한 러닝이 없어요.\n러닝 탭에서 첫 기록을 남겨보세요!"
                android:textColor="@color/textGrey"
                android:textSize="13sp"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/bottom_nav" />
</LinearLayout>
