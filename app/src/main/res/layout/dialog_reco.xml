<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_bg"
    android:orientation="vertical"
    android:padding="22dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🗺 추천 코스"
        android:textColor="@color/primary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/recoDlgName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/textDark"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/recoDlgSub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:textColor="@color/textGrey"
        android:textSize="13sp" />

    <com.rundex.routepoc.RoutePreviewView
        android:id="@+id/recoDlgRoute"
        android:layout_width="match_parent"
        android:layout_height="170dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/card_inset" />

    <TextView
        android:id="@+id/recoDlgRun"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/btn_primary"
        android:gravity="center"
        android:text="🏃 이 코스로 달리기"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/recoDlgBookmark"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="@drawable/btn_secondary"
            android:gravity="center"
            android:text="🔖 북마크"
            android:textColor="@color/textDark"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Space android:layout_width="10dp" android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/recoDlgClose"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="@drawable/btn_secondary"
            android:gravity="center"
            android:text="닫기"
            android:textColor="@color/textDark"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
