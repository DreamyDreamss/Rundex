<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 풀스크린(상태바 숨김). 시스템 내비게이션 바는 유지하되 콘텐츠를 그 위로 밀어 올린다 -->
    <style name="AppTheme" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- 앱 톤에 맞춘 둥근 다이얼로그 (시스템 기본 팝업 탈피) -->
    <style name="RundexDialog" parent="@android:style/Theme.Material.Light.Dialog.NoActionBar">
        <item name="android:windowBackground">@drawable/dialog_bg</item>
        <item name="android:colorAccent">@color/primary</item>
        <item name="android:textColorPrimary">@color/textDark</item>
        <item name="android:windowMinWidthMajor">88%</item>
        <item name="android:windowMinWidthMinor">88%</item>
    </style>
</resources>
